#!/usr/bin/env bash
# psis — Pacific Shore Innovation Skills CLI wrapper
#
# SETUP (add to ~/.zshrc):
#   export ANTHROPIC_API_KEY=sk-ant-...
#   export PSIS_IMAGE=ghcr.io/pacific-shore-innovations-llc/agent-skills:latest
#   alias psis='path/to/psis'   # or copy this script to somewhere on your PATH
#
# USAGE:
#   psis --project utilityiou --skill prioritize n=3
#   psis --project utilityiou --skill issue-ticket
#   psis --project utilityiou --skill review-pr --branch feature/my-branch
#   psis --project utilityiou --skill plan-issue
#
# UNSUPPORTED (use VS Code instead):
#   psis --project utilityiou --skill implement-issue  ← requires local checkout

set -euo pipefail

IMAGE="${PSIS_IMAGE:-ghcr.io/pacific-shore-innovations-llc/agent-skills:latest}"

# ─── Validate Anthropic API key present before spinning up container ─────────
if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
    echo "ERROR: ANTHROPIC_API_KEY is not set." >&2
    echo "       Add to ~/.zshrc: export ANTHROPIC_API_KEY=sk-ant-..." >&2
    exit 1
fi

# ─── Validate gh CLI is available and authenticated ──────────────────────────
if ! command -v gh &>/dev/null; then
    echo "ERROR: GitHub CLI (gh) is not installed or not on PATH." >&2
    echo "       Install: https://cli.github.com" >&2
    exit 1
fi

GITHUB_TOKEN=$(gh auth token 2>/dev/null || true)
if [[ -z "$GITHUB_TOKEN" ]]; then
    echo "ERROR: Not authenticated with GitHub CLI." >&2
    echo "       Run: gh auth login" >&2
    exit 1
fi

# ─── Detect container runtime ────────────────────────────────────────────────
if command -v docker &>/dev/null; then
    RUNTIME="docker"
elif command -v podman &>/dev/null; then
    RUNTIME="podman"
else
    echo "ERROR: Neither Docker nor Podman found on PATH." >&2
    echo "       Install Docker Desktop: https://www.docker.com/products/docker-desktop" >&2
    exit 1
fi

# ─── Run ─────────────────────────────────────────────────────────────────────
exec "$RUNTIME" run --rm -it \
    -e ANTHROPIC_API_KEY \
    -e GITHUB_TOKEN \
    "$IMAGE" \
    "$@"
